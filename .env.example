# Base URL — set this in Vercel dashboard or locally
# For local dev: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: Cloudflare API token for higher rate limits on Radar API
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Free tier works without this too
CLOUDFLARE_API_TOKEN=ayVgZp-F4H1xXOmqPZWjO8rEMiLF28ouihkDzDDJ

# Telegram Bot API — monitors Kerala channels for outage keywords
# Step 1: Message @BotFather on Telegram → /newbot → copy the token
# Step 2: Add your bot to the KSEB/Kerala channels as a member
# Step 3: Get chat IDs — forward any message from the channel to @userinfobot
# Step 4: Fill both vars below (comma-separate multiple chat IDs)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
